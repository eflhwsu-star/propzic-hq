# PROPZIC HQ 환경변수
# 이 파일을 .env로 복사 후 실제 값 입력

# Anthropic Claude API (필수)
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 카카오톡 나에게 보내기 (브리핑 발송용)
# 발급: https://developers.kakao.com → 애플리케이션 → 내 애플리케이션 → 카카오 로그인 → 동의항목 설정
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
KAKAO_REST_API_KEY=
